# Auto-detect text files, normalize line endings to LF on checkin.
* text=auto eol=lf

# Source & config stay as normal text in git (diffable/mergeable).
*.cs        text diff=csharp
*.shader    text
*.shadergraph text
*.cginc     text
*.hlsl      text
*.json      text
*.txt       text
*.md        text
*.asmdef    text
*.inputactions text

# Unity YAML assets are text — keep diffs/merges working.
*.unity     text
*.prefab    text
*.asset     text
*.mat       text
*.controller text
*.anim      text
*.meta      text

# ---- Binary assets: stored as normal git blobs (NOT LFS), no EOL conversion ----
# `binary` = -text -diff -merge. Fine on GitHub free while files stay well under 100MB.
# Images
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.bmp   binary
*.tga   binary
*.tif   binary
*.tiff  binary
*.psd   binary
*.exr   binary
*.hdr   binary
# 3D models
*.fbx   binary
*.obj   binary
*.blend binary
*.dae   binary
*.3ds   binary
*.max   binary
# Audio
*.wav   binary
*.mp3   binary
*.ogg   binary
*.aif   binary
*.aiff  binary
# Video
*.mp4   binary
*.mov   binary
# Fonts
*.ttf   binary
*.otf   binary
# Other binaries
*.unitypackage binary
*.dll   binary
*.a     binary
*.so    binary
*.bundle binary
*.cubemap binary
*.wlt   binary
